{
  "default": {
    "identifier": "default",
    "description": "Default permissions for the main window",
    "local": true,
    "windows": ["main"],
    "permissions": [
      "core:default",
      "core:event:default",
      "core:window:default",
      "core:window:allow-show",
      "core:window:allow-hide",
      "core:window:allow-set-focus",
      "core:webview:default",
      "shell:allow-execute",
      "shell:allow-spawn",
      "shell:allow-stdin-write",
      "shell:allow-kill",
      "shell:allow-open",
      "os:default",
      "process:default",
      "process:allow-exit",
      "fs:default",
      "dialog:default",
      "dialog:allow-open",
      "dialog:allow-save",
      "clipboard-manager:default",
      "clipboard-manager:allow-read-text",
      "clipboard-manager:allow-write-text",
      "opener:default",
      "opener:allow-open-url",
      "log:default"
    ]
  }
}
